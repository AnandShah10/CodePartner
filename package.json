{
  "name": "codepartner",
  "displayName": "CodePartner",
  "description": "A user-friendly AI co-pilot to help build code, find bugs, and give solutions.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codepartner.helloWorld",
        "title": "Hello World"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codepartner-view-container",
          "title": "CodePartner",
          "icon": "$(robot)"
        }
      ]
    },
    "views": {
      "codepartner-view-container": [
        {
          "type": "webview",
          "id": "codepartner-sidebar",
          "name": "CodePartner Chat",
          "icon": "$(robot)",
          "contextualTitle": "CodePartner Chat AI"
        }
      ]
    },
    "configuration": {
      "title": "CodePartner",
      "properties": {
        "codepartner.provider": {
          "type": "string",
          "enum": [
            "openai",
            "azure"
          ],
          "default": "openai",
          "description": "LLM provider type"
        },
        "codepartner.apiEndpoint": {
          "type": "string",
          "default": "https://api.openai.com/v1",
          "description": "LLM API endpoint"
        },
        "codepartner.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for the LLM provider."
        },
        "codepartner.model": {
          "type": "string",
          "default": "gpt-4",
          "description": "Model name (OpenAI) or Deployment name (Azure)"
        },
        "codepartner.maxTokens": {
          "type": "number",
          "default": 1024,
          "description": "Max output tokens."
        },
        "codepartner.azureApiVersion": {
          "type": "string",
          "default": "2024-02-15-preview",
          "description": "Azure OpenAI API version (only used when provider=azure)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.11",
    "@types/vscode": "^1.86.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "eventsource-parser": "^3.0.6",
    "markdown-it": "^14.1.0",
    "puppeteer-core": "^24.40.0"
  }
}
